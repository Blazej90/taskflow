rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /tasks/{taskId} {

      allow get, list: if signedIn() 
        && resource.data.userId == request.auth.uid;

      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.status in ['todo', 'doing', 'done']
        && request.resource.data.order is number;

      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && isValidOptionalString(request.resource.data, 'title', 1, 200)
        && isValidOptionalStatus(request.resource.data, 'status')
        && isValidOptionalNumber(request.resource.data, 'order')
        && isValidOptionalString(request.resource.data, 'description', 0, 2000);

      allow delete: if signedIn()
        && resource.data.userId == request.auth.uid;

    }


    function signedIn() {
      return request.auth != null;
    }

    function isValidOptionalString(data, field, minLen, maxLen) {
      return !data.keys().hasAny([field]) 
        || (data[field] is string 
            && data[field].size() >= minLen 
            && data[field].size() <= maxLen);
    }

    function isValidOptionalStatus(data, field) {
      return !data.keys().hasAny([field]) 
        || data[field] in ['todo', 'doing', 'done'];
    }

    function isValidOptionalNumber(data, field) {
      return !data.keys().hasAny([field]) 
        || data[field] is number;
    }

  }
}
