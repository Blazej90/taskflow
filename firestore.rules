rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Tasks collection - users can only access their own tasks
    match /tasks/{taskId} {
      // Allow read only if task belongs to authenticated user
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      
      // Allow create only if setting userId to current user
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      
      // Allow update only if task belongs to current user AND userId is not changed
      allow update: if request.auth != null 
        && request.auth.uid == resource.data.userId 
        && request.auth.uid == request.resource.data.userId;
      
      // Allow delete only if task belongs to current user
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
  }
}
